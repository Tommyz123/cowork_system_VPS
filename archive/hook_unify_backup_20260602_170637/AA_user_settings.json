        "repo": "anthropics/claude-plugins-official"
      }
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "language": "中文",
  "skipDangerousModePermissionPrompt": true,
  "theme": "light"
}
